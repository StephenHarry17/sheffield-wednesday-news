generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleType {
  news
  match_preview
  match_report
  opinion
  feature
  transfer
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  name     String?
  articles Article[]
  comments Comment[]
}

model Article {
  id           Int         @id @default(autoincrement())
  title        String
  content      String
  excerpt      String?
  slug         String      @unique
  published    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  authorId     Int

  articleType  ArticleType @default(news)
  matchId      String?
  matchDate    String?
  opponent     String?
  competition  String?
  isHero       Boolean     @default(false)
  heroImageUrl String?

  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]

  @@index([published, articleType])
  @@index([matchId])
  @@index([matchDate])
  @@index([isHero])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  articleId Int
  authorId  Int
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Match {
  id          String   @id @default(cuid())
  home        String
  away        String
  date        String
  time        String
  venue       String
  competition String
  score       String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id           String   @id @default(cuid())
  title        String
  videoId      String   @unique
  thumbnail    String
  publishedAt  DateTime
  description  String?
  channelTitle String?
  isOfficial   Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  excerpt     String?
  content     String?
  source      String
  sourceUrl   String    @unique
  imageUrl    String?
  category    String
  summary     String?
  sentiment   String?
  isBreaking  Boolean   @default(false)
  viewCount   Int       @default(0)
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([source])
  @@index([category])
  @@index([createdAt])
  @@index([isBreaking])
}

model BreakingNewsSummary {
  id          String   @id @default(cuid())
  summary     String
  keyPoints   String[]
  articleIds  String[]
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model NewsSource {
  id            String    @id @default(cuid())
  name          String    @unique
  url           String?
  type          String
  enabled       Boolean   @default(true)
  lastFetchedAt DateTime?
  errorCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LeagueTableEntry {
  id             String   @id @default(cuid())
  position       Int
  teamId         Int
  teamName       String
  playedGames    Int
  won            Int
  draw           Int
  lost           Int
  points         Int
  goalsFor       Int
  goalsAgainst   Int
  goalDifference Int
  form           String?
  competition    String
  season         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([competition, teamId])
  @@index([competition, position])
}